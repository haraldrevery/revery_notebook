{
  "name": "revery-notebook-desktop",
  "version": "1.0.0",
  "description": "Revery Notebook — Desktop wrapper (Electron + Tauri)",
  "private": true,
  "main": "electron/main.js",
  "homepage": "https://haraldrevery.com",
  "author": {
    "name": "Harald Revery",
    "email": "contact@haraldrevery.com"
  },
  "scripts": {
    "start:electron": "electron .",
    "build:electron": "electron-builder",
    "start:tauri": "tauri dev   --config tauri/tauri.conf.json",
    "build:tauri": "tauri build --config tauri/tauri.conf.json",
    "test": "node --test \"test/**/*.test.js\""
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.haraldrevery.notebook",
    "productName": "Revery Notebook",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "www/**/*",
      "electron/**/*",
      "!www/dev.sh",
      "!www/dev.bat",
      "!www/tailwindcss-linux-x64",
      "!www/css_aesthetics/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "icon": "tauri/icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "tauri/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Harald Revery Mark Thirslund <contact@haraldrevery.com>",
      "icon": "tauri/icons"
    }
  }
}
